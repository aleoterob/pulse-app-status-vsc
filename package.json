{
  "name": "pulse-app-status",
  "publisher": "AleOtero",
  "displayName": "Pulse App Status",
  "description": "Inspect localhost ports and stop processes quickly. Supports Node.js, Bun and Python apps, and Docker containers.",
  "version": "0.0.5",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/pulse-logo.png",
  "activationEvents": [],
  "sponsor": {
    "url": "https://paypal.me/aleoterob"
  },
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "portkilla-panel",
          "title": "PULSE",
          "icon": "media/pulse-logo.png"
        }
      ]
    },
    "views": {
      "portkilla-panel": [
        {
          "type": "webview",
          "id": "portkilla-panel-view",
          "name": "PULSE"
        }
      ]
    },
    "commands": [
      {
        "command": "portkilla.run-portkilla",
        "title": "Run Pulse App Status"
      },
      {
        "command": "portkilla.refresh-processes",
        "title": "Refresh Processes",
        "icon": "$(refresh)"
      },
      {
        "command": "portkilla.open-extension-details",
        "title": "Extension Details",
        "icon": "$(info)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "portkilla.refresh-processes",
          "when": "view == portkilla-panel-view",
          "group": "navigation@-100"
        },
        {
          "command": "portkilla.open-extension-details",
          "when": "view == portkilla-panel-view",
          "group": "navigation@-90"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
